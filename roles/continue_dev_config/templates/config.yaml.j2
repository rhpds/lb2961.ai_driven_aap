name: AIOps Workshop
version: 0.0.1
schema: v1
models:
  - name: Gemini
    provider: gemini
    model: gemini-2.5-pro
    apiKey: ""
{% if continue_dev_mcp_enabled | bool %}
{% set _toolsets = ['job_management', 'inventory_management', 'system_monitoring', 'user_management', 'security_compliance', 'platform_configuration'] %}
{% set _names = ['aap-job-mgmt', 'aap-inventory', 'aap-monitoring', 'aap-user-mgmt', 'aap-security', 'aap-config'] %}
{% if continue_dev_mcp_mode == "standalone" %}
mcpServers:
{% for i in range(_toolsets | length) %}
  - name: {{ _names[i] }}
    command: /home/{{ student_name }}/.nvm/nvm-exec
    args:
      - npx
      - -y
      - mcp-remote
      - "http://localhost:{{ continue_dev_mcp_port }}/mcp/{{ _toolsets[i] }}"
      - --header
      - "Authorization: Bearer {{ continue_dev_mcp_token }}"
{% endfor %}
{% elif continue_dev_mcp_mode == "remote" %}
mcpServers:
{% for i in range(_toolsets | length) %}
  - name: {{ _names[i] }}
    command: /home/{{ student_name }}/.nvm/nvm-exec
    args:
      - npx
      - -y
      - mcp-remote
      - "https://{{ continue_dev_mcp_gateway_host }}:8448/{{ _toolsets[i] }}/mcp"
      - --header
      - "Authorization: Bearer {{ continue_dev_mcp_token }}"
    env:
      NODE_TLS_REJECT_UNAUTHORIZED: "0"
{% endfor %}
{% endif %}
{% endif %}
