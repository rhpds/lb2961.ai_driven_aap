{
  "hasCompletedOnboarding": true,
  "customApiKeyResponses": {
{% if (_claude_api_key | trim | length) > 5 %}
    "approved": ["{{ (_claude_api_key | trim)[5:] }}"],
{% else %}
    "approved": [],
{% endif %}
    "rejected": []
  },
  "mcpServers": {
{% if ai_client_mcp_enabled | bool %}
{% set _toolsets = ['job_management', 'inventory_management', 'system_monitoring', 'user_management', 'security_compliance', 'platform_configuration'] %}
{% set _names = ['aap-job-mgmt', 'aap-inventory', 'aap-monitoring', 'aap-user-mgmt', 'aap-security', 'aap-config'] %}
{% for i in range(_toolsets | length) %}
    "{{ _names[i] }}": {
      "command": "/home/{{ student_name }}/.nvm/nvm-exec",
      "args": [
        "npx",
        "-y",
        "mcp-remote@{{ mcp_remote_version }}",
{% if ai_client_mcp_mode == "standalone" %}
        "http://localhost:{{ ai_client_mcp_port }}/mcp/{{ _toolsets[i] }}",
{% elif ai_client_mcp_mode == "remote" %}
        "https://{{ ai_client_mcp_gateway_host }}:8448/{{ _toolsets[i] }}/mcp",
{% endif %}
        "--header",
        "Authorization: Bearer {{ ai_client_mcp_token }}"
      ],
      "env": {
        "NODE_VERSION": "{{ ai_client_node_version }}"
{% if ai_client_mcp_mode == "remote" %}
        ,"NODE_TLS_REJECT_UNAUTHORIZED": "0"
{% endif %}
      }
    }{{ "," if not loop.last or (ai_client_lightspeed_mcp_enabled | default(false) | bool) else "" }}
{% endfor %}
{% endif %}
{% if ai_client_lightspeed_mcp_enabled | default(false) | bool %}
    "lightspeed-mcp": {
      "command": "/home/{{ student_name }}/.nvm/nvm-exec",
      "args": [
        "npx",
        "-y",
        "mcp-remote@{{ mcp_remote_version }}",
        "http://localhost:{{ ai_client_lightspeed_mcp_port }}/mcp",
        "--header",
        "lightspeed-client-id: {{ ai_client_lightspeed_mcp_client_id }}",
        "--header",
        "lightspeed-client-secret: {{ ai_client_lightspeed_mcp_client_secret }}"
      ],
      "env": {
        "NODE_VERSION": "{{ ai_client_node_version }}"
      }
    }
{% endif %}
  }
}
