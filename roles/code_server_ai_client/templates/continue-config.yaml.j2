name: AIOps Workshop
version: 0.0.1
schema: v1
models:
  - name: {{ continue_dev_model_name }}
    provider: {{ continue_dev_model_provider }}
    model: {{ continue_dev_model_id }}
    apiKey: "{{ continue_dev_model_api_key }}"
{% if ai_client_mcp_enabled | bool %}
{% set _toolsets = ['job_management', 'inventory_management', 'system_monitoring', 'user_management', 'security_compliance', 'platform_configuration'] %}
{% set _names = ['aap-job-mgmt', 'aap-inventory', 'aap-monitoring', 'aap-user-mgmt', 'aap-security', 'aap-config'] %}
{% if ai_client_mcp_mode == "standalone" %}
mcpServers:
{% for i in range(_toolsets | length) %}
  - name: {{ _names[i] }}
    command: /home/{{ student_name }}/.nvm/nvm-exec
    args:
      - npx
      - -y
      - mcp-remote
      - "http://localhost:{{ ai_client_mcp_port }}/mcp/{{ _toolsets[i] }}"
      - --header
      - "Authorization: Bearer {{ ai_client_mcp_token }}"
    env:
      NODE_VERSION: "{{ ai_client_node_version }}"
{% endfor %}
{% elif ai_client_mcp_mode == "remote" %}
mcpServers:
{% for i in range(_toolsets | length) %}
  - name: {{ _names[i] }}
    command: /home/{{ student_name }}/.nvm/nvm-exec
    args:
      - npx
      - -y
      - mcp-remote
      - "https://{{ ai_client_mcp_gateway_host }}:8448/{{ _toolsets[i] }}/mcp"
      - --header
      - "Authorization: Bearer {{ ai_client_mcp_token }}"
    env:
      NODE_VERSION: "{{ ai_client_node_version }}"
      NODE_TLS_REJECT_UNAUTHORIZED: "0"
{% endfor %}
{% endif %}
{% endif %}
