#!/usr/bin/env python3
"""
Agentic AIOps Incident Response
================================
A CrewAI multi-agent workflow that uses Ansible Automation Platform
as its trusted execution layer via MCP (Model Context Protocol).
The agents are problem-agnostic -- they discover available AAP
automation dynamically through MCP tools and reason about whether
existing job templates can solve the reported problem.

Architecture:
  Triage Agent    -> understands the problem, discovers available AAP automation
  Executor Agent  -> runs selected job templates, interprets results
  Reporter Agent  -> produces incident report with findings and recommendations

The agents do NOT run commands directly. They interact exclusively
through AAP via MCP tools -- AI decides WHAT to do, Ansible handles
HOW to do it safely and at scale.

Infrastructure:
  LLM:   Claude via Anthropic proxy (localhost:{{ ai_client_proxy_port | default('8443') }})
  Tools:  AAP MCP server (localhost:{{ mcp_server_port | default('8448') }})

Usage:
  python3 incident_agent.py "Apache is down on node1"
  python3 incident_agent.py "Check if crond is running on node1"
  python3 incident_agent.py "PostgreSQL database is down on node1"
  python3 incident_agent.py --break-first "Apache is down on node1"
"""

import argparse
import asyncio
import json
import os
import sys
import time

try:
    from crewai import Agent, Crew, Task, Process
    from crewai.tools import tool
except ImportError:
    print("CrewAI is not installed. Run: pip install crewai crewai-tools")
    sys.exit(1)

try:
    from mcp import ClientSession
    from mcp.client.streamable_http import streamablehttp_client
except ImportError:
    print("MCP client is not installed. Run: pip install mcp")
    sys.exit(1)

# ---------------------------------------------------------------------------
# Configuration from environment (set by ansible_dev_env role)
# ---------------------------------------------------------------------------
MCP_BASE_URL = os.environ.get(
    "MCP_BASE_URL",
    "http://localhost:{{ mcp_server_port | default('8448') }}"
)
MCP_TOKEN = os.environ.get("MCP_TOKEN", "{{ ai_client_mcp_token | default('') }}")

LLM_BASE_URL = os.environ.get(
    "ANTHROPIC_BASE_URL",
    "http://127.0.0.1:{{ ai_client_proxy_port | default('8443') }}"
)
LLM_API_KEY = os.environ.get("ANTHROPIC_API_KEY", "")
LLM_MODEL = os.environ.get("LLM_MODEL", "claude-sonnet-4-6")

# AAP credentials for --break-first only (direct API call)
AAP_BASE_URL = os.environ.get(
    "AAP_BASE_URL",
    "{{ ansible_automation_platform_configuration_host }}"
)
AAP_USERNAME = os.environ.get("AAP_USERNAME", "{{ student_name }}")
AAP_PASSWORD = os.environ.get("AAP_PASSWORD", "{{ common_password }}")


# ---------------------------------------------------------------------------
# MCP Client: discover and call AAP tools via MCP server
# ---------------------------------------------------------------------------
class MCPToolkit:
    """Connects to the AAP MCP server and exposes tools for CrewAI."""

    def __init__(self, base_url, token):
        self.base_url = base_url.rstrip("/")
        self.token = token
        self._tools_cache = {}

    async def _call_mcp_tool(self, toolset, tool_name, arguments=None):
        """Call a single MCP tool on the given toolset endpoint."""
        url = f"{self.base_url}/mcp/{toolset}"
        headers = {}
        if self.token:
            headers["Authorization"] = f"Bearer {self.token}"

        async with streamablehttp_client(url, headers=headers) as (r, w, _):
            async with ClientSession(r, w) as session:
                await session.initialize()
                result = await session.call_tool(tool_name, arguments or {})
                # MCP returns content as a list of content blocks
                texts = []
                for block in result.content:
                    if hasattr(block, "text"):
                        texts.append(block.text)
                return "\n".join(texts)

    async def discover_tools(self, toolset):
        """List available tools from an MCP toolset endpoint."""
        url = f"{self.base_url}/mcp/{toolset}"
        headers = {}
        if self.token:
            headers["Authorization"] = f"Bearer {self.token}"

        async with streamablehttp_client(url, headers=headers) as (r, w, _):
            async with ClientSession(r, w) as session:
                await session.initialize()
                tools = await session.list_tools()
                return tools.tools

    def call_tool_sync(self, toolset, tool_name, arguments=None):
        """Synchronous wrapper for calling MCP tools (thread-safe)."""
        return asyncio.run(
            self._call_mcp_tool(toolset, tool_name, arguments)
        )


mcp_toolkit = MCPToolkit(MCP_BASE_URL, MCP_TOKEN)


# ---------------------------------------------------------------------------
# CrewAI Tools -- wrappers around MCP operations
# ---------------------------------------------------------------------------
@tool("List All Job Templates")
def list_all_job_templates() -> str:
    """List ALL available job templates in AAP with their names and descriptions.
    Use this to discover what automation is available before deciding on a plan."""
    return mcp_toolkit.call_tool_sync(
        "job_management", "job_templates_list", {"page_size": 50}
    )


@tool("Get Job Template Details")
def get_job_template_details(template_id: str) -> str:
    """Get detailed information about a specific job template by its ID.
    Use this to understand what a template does before launching it."""
    return mcp_toolkit.call_tool_sync(
        "job_management", "job_templates_retrieve", {"id": template_id}
    )


@tool("Launch Job Template")
def launch_job_template(template_id: str) -> str:
    """Launch an AAP job template by its ID and return the launched job info.
    Use this to run automation. You must poll the job status separately."""
    return mcp_toolkit.call_tool_sync(
        "job_management", "job_templates_launch_create", {"id": template_id}
    )


@tool("Get Job Status")
def get_job_status(job_id: str) -> str:
    """Check the status of a running or completed job by its ID.
    Status values: pending, waiting, running, successful, failed, error, canceled."""
    return mcp_toolkit.call_tool_sync(
        "job_management", "jobs_retrieve", {"id": job_id}
    )


@tool("Get Job Output")
def get_job_output(job_id: str) -> str:
    """Get the stdout output of a completed job. Use this to see what happened."""
    return mcp_toolkit.call_tool_sync(
        "job_management", "jobs_stdout_retrieve", {"id": job_id}
    )


@tool("List Recent Jobs")
def get_recent_jobs() -> str:
    """Get the most recent AAP jobs with their status.
    Useful for checking what ran recently and whether anything failed."""
    return mcp_toolkit.call_tool_sync(
        "job_management", "jobs_list", {"page_size": 10, "order_by": "-finished"}
    )


@tool("List Hosts")
def list_hosts() -> str:
    """List all hosts registered in AAP inventories.
    Shows host names and which inventory they belong to."""
    return mcp_toolkit.call_tool_sync(
        "inventory_management", "hosts_list", {"page_size": 50}
    )


@tool("List Inventories")
def list_inventories() -> str:
    """List all inventories in AAP."""
    return mcp_toolkit.call_tool_sync(
        "inventory_management", "inventories_list", {}
    )


# ---------------------------------------------------------------------------
# Agent definitions
# ---------------------------------------------------------------------------
all_tools = [
    list_all_job_templates, get_job_template_details, launch_job_template,
    get_job_status, get_job_output, get_recent_jobs, list_hosts, list_inventories,
]

triage_agent = Agent(
    role="Incident Triage Specialist",
    goal=(
        "Understand the reported problem, discover what AAP automation is available, "
        "and create an action plan. Determine if existing job templates can address "
        "the problem or if no suitable automation exists."
    ),
    backstory=(
        "You are an expert at triaging infrastructure incidents. Your first step is "
        "always to discover what automation is available in AAP by listing all job "
        "templates. You then assess whether any of them are relevant to the reported "
        "problem. You check host inventory to confirm the target exists. You are "
        "honest when no suitable automation is available -- you never try to force "
        "an unrelated template to solve a problem it was not designed for."
    ),
    tools=all_tools,
    verbose=True,
    llm=f"anthropic/{LLM_MODEL}",
)

executor_agent = Agent(
    role="Automation Executor",
    goal=(
        "Execute the action plan by launching the selected AAP job templates "
        "in the correct order. Interpret the results of each job."
    ),
    backstory=(
        "You are a disciplined automation operator. You only run job templates "
        "that the triage specialist has identified as relevant. You launch "
        "diagnostic templates first, then remediation templates, then verification "
        "templates. You carefully read job output to understand what happened. "
        "If the triage specialist determined that no suitable automation exists, "
        "you acknowledge this and do not attempt to run unrelated templates. "
        "After launching a job, always check its status before reading output."
    ),
    tools=all_tools,
    verbose=True,
    llm=f"anthropic/{LLM_MODEL}",
)

reporter_agent = Agent(
    role="Incident Reporter",
    goal=(
        "Produce a clear, actionable incident report summarizing what was found, "
        "what was done, and what the outcome was."
    ),
    backstory=(
        "You are a technical writer who creates concise incident reports. "
        "Your reports always include: problem summary, available automation, "
        "actions taken (or why no action was possible), results, and "
        "recommendations. When no automation was available, you recommend "
        "what Ansible playbooks and job templates should be created."
    ),
    tools=[],
    verbose=True,
    llm=f"anthropic/{LLM_MODEL}",
)


# ---------------------------------------------------------------------------
# Task definitions
# ---------------------------------------------------------------------------
def build_tasks(problem_description):
    """Build the task pipeline for any given problem."""

    triage = Task(
        description=(
            f"A problem has been reported:\n\n"
            f"  \"{problem_description}\"\n\n"
            f"Your job:\n"
            f"1. List ALL available job templates in AAP to see what automation exists\n"
            f"2. List all hosts to confirm the target infrastructure exists\n"
            f"3. Check recent job history for related failures\n"
            f"4. Assess which templates (if any) are relevant to this problem\n"
            f"5. Create an action plan:\n"
            f"   - If relevant templates exist: list them in order (diagnose, fix, verify)\n"
            f"   - If NO relevant templates exist: clearly state that no suitable "
            f"     automation was found and explain why\n\n"
            f"Be specific about template names and IDs. Do not suggest templates that are "
            f"unrelated to the reported problem."
        ),
        expected_output=(
            "A triage report containing:\n"
            "- Problem understanding\n"
            "- Available AAP automation (full template list with IDs)\n"
            "- Target host verification\n"
            "- Action plan with specific template names and IDs, OR a clear statement "
            "that no suitable automation exists"
        ),
        agent=triage_agent,
    )

    execute = Task(
        description=(
            "Execute the action plan from the triage report.\n\n"
            "If relevant templates were identified:\n"
            "1. Launch diagnostic template(s) first using the template ID\n"
            "2. After launching, poll the job status until it completes\n"
            "3. Read the job output to confirm the problem\n"
            "4. Launch remediation template(s) to fix the problem\n"
            "5. Poll status and read output\n"
            "6. Launch verification template(s) to confirm the fix\n"
            "7. Poll status and read output\n\n"
            "If no relevant templates were found:\n"
            "- Do NOT run unrelated templates\n"
            "- Acknowledge that automated remediation is not possible\n"
            "- Note what the output would look like if automation existed"
        ),
        expected_output=(
            "An execution log showing:\n"
            "- Which templates were launched (by ID) and their results, OR\n"
            "- A statement that no automation was executed because no suitable "
            "templates exist"
        ),
        agent=executor_agent,
        context=[triage],
    )

    report = Task(
        description=(
            "Create a final incident report based on the triage and execution results.\n\n"
            "The report must include these sections:\n"
            "1. INCIDENT SUMMARY: What problem was reported\n"
            "2. AVAILABLE AUTOMATION: What AAP templates were found\n"
            "3. ACTIONS TAKEN: What was executed and the results\n"
            "4. OUTCOME: Was the problem resolved?\n"
            "5. RECOMMENDATIONS:\n"
            "   - If resolved: how to prevent recurrence\n"
            "   - If NOT resolved: what Ansible playbooks and AAP job templates "
            "     should be created to handle this type of problem in the future. "
            "     Be specific about playbook names, modules to use, and template "
            "     configuration."
        ),
        expected_output=(
            "A formatted incident report with all 5 sections. "
            "For unresolved incidents, the RECOMMENDATIONS section should include "
            "specific Ansible module suggestions and playbook outlines."
        ),
        agent=reporter_agent,
        context=[triage, execute],
    )

    return [triage, execute, report]


# ---------------------------------------------------------------------------
# Break helper (direct API for simulating incident only)
# ---------------------------------------------------------------------------
def break_apache():
    """Use direct API to break Apache -- only used for demo setup."""
    import requests
    import urllib3
    urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)
    s = requests.Session()
    s.verify = False
    s.auth = (AAP_USERNAME, AAP_PASSWORD)
    s.headers["Content-Type"] = "application/json"

    r = s.get(
        f"{AAP_BASE_URL}/api/controller/v2/job_templates/",
        params={"search": "Break Apache"}
    )
    r.raise_for_status()
    for t in r.json().get("results", []):
        if t["name"] == "Break Apache":
            job = s.post(
                f"{AAP_BASE_URL}/api/controller/v2/job_templates/{t['id']}/launch/"
            ).json()
            end = time.time() + 120
            while time.time() < end:
                j = s.get(f"{AAP_BASE_URL}/api/controller/v2/jobs/{job['id']}/").json()
                if j["status"] in ("successful", "failed", "error", "canceled"):
                    return j["status"]
                time.sleep(5)
            return "timeout"
    return "template_not_found"


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
def main():
    parser = argparse.ArgumentParser(
        description="Agentic AIOps: AI-driven incident response using AAP via MCP"
    )
    parser.add_argument(
        "problem",
        nargs="?",
        default="Apache web server is down on node1",
        help="Problem description (default: 'Apache web server is down on node1')"
    )
    parser.add_argument(
        "--break-first", action="store_true",
        help="Run 'Break Apache' template first to simulate an incident"
    )
    args = parser.parse_args()

    # Suppress SSL warnings for lab environment
    import urllib3
    urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

    print(f"\n{'='*60}")
    print("AGENTIC AIOPS INCIDENT RESPONSE")
    print(f"{'='*60}")
    print(f"LLM:   {LLM_MODEL} via proxy at {LLM_BASE_URL}")
    print(f"Tools: AAP MCP server at {MCP_BASE_URL}")

    if args.break_first:
        print(f"\nSimulating incident...")
        status = break_apache()
        if status == "successful":
            print("Done. Apache is now broken.\n")
        elif status == "template_not_found":
            print("WARNING: 'Break Apache' template not found.\n")
        else:
            print(f"WARNING: Break job ended with status: {status}\n")

    print(f"\nProblem: {args.problem}")
    print(f"{'='*60}\n")

    # Configure CrewAI to use our LLM proxy
    os.environ["ANTHROPIC_API_KEY"] = LLM_API_KEY
    os.environ["ANTHROPIC_BASE_URL"] = LLM_BASE_URL

    tasks = build_tasks(args.problem)

    crew = Crew(
        agents=[triage_agent, executor_agent, reporter_agent],
        tasks=tasks,
        process=Process.sequential,
        verbose=True,
    )

    result = crew.kickoff()

    print(f"\n{'='*60}")
    print("FINAL REPORT")
    print(f"{'='*60}\n")
    print(result)


if __name__ == "__main__":
    main()
